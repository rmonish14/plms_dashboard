# ─────────────────────────────────────────────────────────────────────────────
# PLMS Unified Environment Variables
# Copy this file to .env and fill in real values before running the server
# ─────────────────────────────────────────────────────────────────────────────

# --- Backend Configuration ---

# PostgreSQL — connection string
DATABASE_URL=postgresql://aqms_user:yourpassword@host/aqms

# Server Port
PORT=5000

# MQTT Broker (HiveMQ public — replace with private broker for production)
HIVEMQ_URL=mqtt://broker.hivemq.com:1883

# JWT
JWT_SECRET=change_this_to_a_long_random_secret_in_production

# Sensor Thresholds (optional — these are the defaults)
THRESHOLD_PM25=100
THRESHOLD_CO2=1000
THRESHOLD_TEMP=35

# SMTP Email Configuration
SMTP_USER=kassandra.glover@ethereal.email
SMTP_PASS=6yC19B4C3g6SZNXStH

# --- Frontend Configuration ---

# Backend API URL (for local development, this is full URL. In production it's empty to use current origin)
VITE_API_URL=http://localhost:5000
